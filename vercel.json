{
    "version": 2,
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/.next",
    "framework": "nextjs",
    "routes": [{
        "src": "/(.*)",
        "dest": "/frontend/$1"
    }],
    "env": {
        "NEXT_PUBLIC_API_URL": "https://app.awaseru.net"
    }
}